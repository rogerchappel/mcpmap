// Custom MCP-ish shape with comments and trailing commas.
{
  "servers": {
    "notes": {
      "command": "node",
      "args": ["server.js",],
      "env": {
        "NOTES_DIR": "~/notes",
      },
    },
    "archived": {
      "command": "node",
      "args": ["old-server.js"],
      "disabled": true,
    },
  },
}
